# Copy this file to deploy/.env and fill in real values. deploy/.env is
# gitignored and never committed. Run compose from this directory so it picks
# up .env:  cd deploy && docker compose up
#
# These are LOCAL DEV values only. Use a real, non-trivial password anywhere
# the database is reachable beyond your machine.

POSTGRES_USER=vergil
POSTGRES_PASSWORD=change-me
POSTGRES_DB=vergil

# Consumer connection settings. PGPASSWORD is required and has no default in
# code, so the audit consumer refuses to start without it.
PGHOST=localhost
PGPORT=5432
PGUSER=vergil
PGPASSWORD=change-me
PGDATABASE=vergil
